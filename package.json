{
  "name": "place-time",
  "version": "0.1.0",
  "description": "Hexagonal geological-to-political spatial index with logarithmic time-space compression",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc",
    "verify:hexalog": "tsx scripts/verify-hexalog.ts",
    "ingest:geology": "tsx src/ingest/geology.ts",
    "ingest:historical": "tsx src/ingest/historical.ts",
    "ingest:boundaries": "tsx src/ingest/boundaries.ts",
    "ingest:all": "npm run ingest:geology && npm run ingest:historical && npm run ingest:boundaries",
    "build:qgis": "tsx scripts/generate-qgis-project.ts",
    "build:timescale": "tsx scripts/build-timescale.ts",
    "optimise:grid": "tsx scripts/optimise-grid-alignment.ts",
    "generate:h3": "tsx scripts/generate-h3-global-grids.ts",
    "analyse:tectonic": "tsx scripts/tectonic-cell-analysis.ts",
    "build:tectonic": "tsx scripts/build-tectonic-mesh.ts",
    "query": "tsx src/cli/query.ts",
    "ollama:check": "curl -s http://localhost:11434/api/tags | jq ."
  },
  "keywords": [
    "gis",
    "geology",
    "geopolitics",
    "qgis",
    "historical-maps",
    "gerrymandering",
    "h3",
    "hexagonal-grid",
    "ollama",
    "embeddings"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/rbush": "^4.0.0",
    "cesium": "^1.141.0",
    "geojson": "^0.5.0",
    "h3-js": "^4.4.0",
    "ollama": "^0.6.3",
    "rbush": "^4.0.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-cesium": "^1.2.23"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.8.0"
  }
}
